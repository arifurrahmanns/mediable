{
  "name": "@mediable/example-fastify",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate": "tsx --eval \"import('./src/media.ts').then(m => m.media.migrate())\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mediable": "workspace:*",
    "fastify": "^5.8.5",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
