{
  "name": "@mediable/example-fastify",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate": "tsx --eval \"import('./src/media.ts').then(m => m.media.migrate())\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mediable": "workspace:*",
    "fastify": "^5.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
