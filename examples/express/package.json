{
  "name": "@mediable/example-express",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate": "tsx --eval \"import('./src/media.ts').then(m => m.media.migrate())\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mediable": "workspace:*",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
