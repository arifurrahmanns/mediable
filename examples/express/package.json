{
  "name": "@mediable/example-express",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate": "tsx --eval \"import('./src/media.ts').then(m => m.media.migrate())\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mediable": "workspace:*",
    "express": "^5.2.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
