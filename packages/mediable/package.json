{
  "name": "mediable",
  "version": "0.2.0",
  "description": "Headless, framework-agnostic media library for Node.js. Attach files to any model with named collections, image conversions, pluggable storage (local FS, S3 / R2 / MinIO / B2) and databases (SQLite, Postgres, MySQL, MongoDB).",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Arif Ur Rahman",
    "url": "https://github.com/arifurrahmanns"
  },
  "homepage": "https://github.com/arifurrahmanns/mediable#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arifurrahmanns/mediable.git",
    "directory": "packages/mediable"
  },
  "bugs": {
    "url": "https://github.com/arifurrahmanns/mediable/issues"
  },
  "keywords": [
    "media",
    "media-library",
    "file-uploads",
    "uploads",
    "attachments",
    "image-processing",
    "thumbnails",
    "conversions",
    "storage",
    "signed-urls",
    "sharp",
    "bullmq",
    "s3",
    "aws-s3",
    "cloudflare-r2",
    "minio",
    "backblaze-b2",
    "postgres",
    "mysql",
    "sqlite",
    "mongodb",
    "express",
    "nestjs",
    "hono",
    "fastify",
    "nextjs",
    "typescript",
    "nodejs"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./sharp": {
      "types": "./dist/sharp/index.d.ts",
      "import": "./dist/sharp/index.js",
      "require": "./dist/sharp/index.cjs"
    },
    "./bullmq": {
      "types": "./dist/bullmq/index.d.ts",
      "import": "./dist/bullmq/index.js",
      "require": "./dist/bullmq/index.cjs"
    },
    "./mongoose": {
      "types": "./dist/mongoose/index.d.ts",
      "import": "./dist/mongoose/index.js",
      "require": "./dist/mongoose/index.cjs"
    },
    "./s3": {
      "types": "./dist/s3/index.d.ts",
      "import": "./dist/s3/index.js",
      "require": "./dist/s3/index.cjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "mediable": "./bin/mediable.mjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "better-sqlite3": "^12.9.0",
    "bullmq": "^5.75.2",
    "file-type": "^22.0.1",
    "jiti": "^2.6.1",
    "kysely": "^0.28.16",
    "mongoose": "^9.5.0",
    "mysql2": "^3.22.1",
    "nanoid": "^5.1.9",
    "pg": "^8.20.0",
    "prompts": "^2.4.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.20.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
